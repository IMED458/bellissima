rules_version = '2';

// Bellissima CRM — Firestore წესები
// ⚠️ აპლიკაცია იყენებს საკუთარ (custom) ავტორიზაციას employees კოლექციით,
// და არა Firebase Authentication-ს. ამიტომ წვდომა ღიაა.
// თუ მომავალში დაემატება Firebase Auth, აქ უნდა გამკაცრდეს წესები.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
